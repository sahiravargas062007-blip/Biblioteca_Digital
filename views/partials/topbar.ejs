<%
  var isAdmin = session && session.adminId;
  var isUser  = session && session.userId && !isAdmin;
  var isHero  = typeof topbarHero !== 'undefined' && topbarHero;
  var isLogin = typeof currentPath !== 'undefined' && currentPath === '/login';

  function isActive(prefix) {
    if (typeof currentPath === 'undefined') return '';
    return currentPath.startsWith(prefix) ? 'is-active' : '';
  }
%>

<!-- ── Sidebar Navigation (Admin Only) ── -->
<% if (isAdmin) { %>
<aside class="cat-sidebar is-collapsed" id="cat-sidebar">
  <div class="cat-sidebar__header">
    <a class="cat-sidebar__brand" href="/admin/dashboard">
      BiblioNet
      <small>Conecta con el conocimiento</small>
    </a>
  </div>
  <nav class="cat-sidebar__nav">
    <a class="cat-sidebar__link <%= isActive('/admin/dashboard') %>" href="/admin/dashboard">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        Dashboard
      </a>
      <a class="cat-sidebar__link <%= isActive('/admin/recursos') %>" href="/admin/recursos">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg>
        Materiales
      </a>
      <a class="cat-sidebar__link <%= isActive('/admin/categorias') %>" href="/admin/categorias">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/></svg>
        Categorías
      </a>
      <a class="cat-sidebar__link <%= isActive('/admin/usuarios') %>" href="/admin/usuarios">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
        Usuarios
      </a>
      <a class="cat-sidebar__link <%= isActive('/admin/prestamos') %>" href="/admin/prestamos">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg>
        Préstamos
      </a>
      <a class="cat-sidebar__link <%= isActive('/admin/reservas') %>" href="/admin/reservas">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        Reservas
      </a>
      <a class="cat-sidebar__link <%= isActive('/admin/sanciones') %>" href="/admin/sanciones">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        Sanciones
      </a>
      <a class="cat-sidebar__link <%= isActive('/admin/reportes') %>" href="/admin/reportes">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
        Reportes
      </a>
      <a class="cat-sidebar__link <%= isActive('/admin/configuracion') %>" href="/admin/configuracion">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
        Configuración
      </a>
  </nav>
</aside>
<% } %>

<div class="cat-sidebar-overlay" id="cat-overlay"></div>

<!-- ── Top Bar ── -->
<header class="cat-topbar <%= isHero ? 'topbar--hero' : '' %>" id="cat-topbar">
  <div class="cat-topbar__left">
    <a class="cat-topbar__brand" href="<%= isAdmin ? '/admin/dashboard' : '/catalogo' %>">
      <img src="/img/biblionet-logo.png" alt="BiblioNet" class="cat-topbar__logo">
      <div class="cat-topbar__brand-text">
        <span class="cat-topbar__brand-name">BiblioNet</span>
        <span class="cat-topbar__brand-slogan">— Conecta con el conocimiento —</span>
      </div>
    </a>
  </div>
  <nav class="cat-topbar__links">
    <% if (isAdmin) { %>
      <a href="/admin/dashboard" class="<%= isActive('/admin/dashboard') %>">Dashboard</a>
      <a href="/admin/recursos" class="<%= isActive('/admin/recursos') %>">Materiales</a>
      <a href="/admin/usuarios" class="<%= isActive('/admin/usuarios') %>">Usuarios</a>
      <a href="/admin/prestamos" class="<%= isActive('/admin/prestamos') %>">Préstamos</a>
    <% } else { %>
      <a href="/catalogo" class="<%= isActive('/catalogo') %>">Explorar</a>
      <a href="/catalogo" class="">Categorías</a>
      <a href="/catalogo" class="">Novedades</a>
      <a href="/catalogo" class="">Más leídos</a>
    <% } %>
  </nav>
  <div class="cat-topbar__right">
    <% if (isAdmin || isUser) { %>
    <div class="user-dropdown-wrapper">
      <button class="cat-topbar__toggle" id="<%= isAdmin ? 'sidebar-toggle' : 'dropdown-toggle' %>" aria-label="Toggle menu">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
      <% if (!isAdmin) { %>
        <div class="user-dropdown-menu" id="user-dropdown">
          <a class="user-dropdown__link <%= isActive('/catalogo') %>" href="/catalogo">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            Explorar
          </a>
          <a class="user-dropdown__link <%= isActive('/prestamos') %>" href="/prestamos">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
            Préstamos
          </a>
          <a class="user-dropdown__link <%= isActive('/reservas') %>" href="/reservas">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            Reservas
          </a>
          <a class="user-dropdown__link <%= isActive('/historial') %>" href="/historial">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="12 6 12 12 16 14"/><circle cx="12" cy="12" r="10"/></svg>
            Historial
          </a>
          <a class="user-dropdown__link <%= isActive('/sanciones') %>" href="/sanciones">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            Sanciones
          </a>
        </div>
      <% } %>
    </div>
      <% if (isUser) { %>
        <a href="/perfil" class="cat-topbar__icon" aria-label="Mi perfil">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </a>
      <% } %>
      <button id="logout-btn" class="cat-topbar__icon" aria-label="Cerrar sesión">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
      </button>
    <% } else if (!isLogin) { %>
      <a href="/login" class="cat-topbar__login-btn" style="display:inline-flex; align-items:center; gap:8px; background:var(--color-primary); color:#fff; text-decoration:none; padding:8px 16px; border-radius:999px; font-family:'Poppins', sans-serif; font-weight:500; font-size:0.92rem; transition:background 0.3s;">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
        Iniciar sesión
      </a>
    <% } %>
  </div>
</header>

<!-- ── Modal de Confirmación de Cierre de Sesión ── -->
<% if (isAdmin || isUser) { %>
<div class="logout-modal-overlay" id="logout-modal-overlay">
  <div class="logout-modal">
    <div class="logout-modal__content">
      <h2 class="logout-modal__title">Cerrar sesión</h2>
      <p class="logout-modal__message">¿Deseas cerrar sesión de BiblioNet?</p>
    </div>
    <div class="logout-modal__actions">
      <button class="logout-modal__btn logout-modal__btn--secondary" id="logout-cancel">
        Cancelar
      </button>
      <button class="logout-modal__btn logout-modal__btn--primary" id="logout-confirm">
        Cerrar sesión
      </button>
    </div>
  </div>
</div>
<% } %>

<script>
(function () {
  /* ── Sidebar (Admin) ── */
  var sidebarToggle = document.getElementById('sidebar-toggle');
  var sidebar = document.getElementById('cat-sidebar');
  var overlay = document.getElementById('cat-overlay');

  if (sidebarToggle && sidebar) {
    sidebarToggle.addEventListener('click', function (e) {
      e.stopPropagation();
      var isCollapsed = sidebar.classList.toggle('is-collapsed');
      if (overlay) overlay.classList.toggle('is-active', !isCollapsed);
    });

    if (overlay) {
      overlay.addEventListener('click', function () {
        sidebar.classList.add('is-collapsed');
        overlay.classList.remove('is-active');
      });
    }
  }

  /* ── Dropdown (User) ── */
  var dropdownToggle = document.getElementById('dropdown-toggle');
  var dropdownMenu = document.getElementById('user-dropdown');
  if (dropdownToggle && dropdownMenu) {
    dropdownToggle.addEventListener('click', function(e) {
      e.stopPropagation();
      dropdownMenu.classList.toggle('is-open');
    });
    document.addEventListener('click', function(e) {
      if (!dropdownToggle.contains(e.target) && !dropdownMenu.contains(e.target)) {
        dropdownMenu.classList.remove('is-open');
      }
    });
  }

  /* ── Scroll for Transparent Topbar ── */
  var topbar = document.getElementById('cat-topbar');
  if (topbar && topbar.classList.contains('topbar--hero')) {
    window.addEventListener('scroll', function () {
      topbar.classList.toggle('topbar--scrolled', window.scrollY > 60);
    }, { passive: true });
  }

  /* ── Logout Modal ── */
  var logoutBtn = document.getElementById('logout-btn');
  var logoutModal = document.getElementById('logout-modal-overlay');
  var cancelBtn = document.getElementById('logout-cancel');
  var confirmBtn = document.getElementById('logout-confirm');

  if (logoutBtn && logoutModal) {
    logoutBtn.addEventListener('click', function (e) {
      e.preventDefault();
      logoutModal.classList.add('is-open');
    });

    if (cancelBtn) {
      cancelBtn.addEventListener('click', function () {
        logoutModal.classList.remove('is-open');
      });
    }

    if (confirmBtn) {
      confirmBtn.addEventListener('click', function () {
        var form = document.createElement('form');
        form.method = 'POST';
        form.action = '<%= isAdmin ? "/admin/logout" : "/logout" %>';
        document.body.appendChild(form);
        form.submit();
      });
    }

    logoutModal.addEventListener('click', function (e) {
      if (e.target === logoutModal) logoutModal.classList.remove('is-open');
    });
  }
})();
</script>
