<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= typeof title !== 'undefined' ? title : 'Admin' %> | Biblioteca Digital</title>
  <!-- CSS Base -->
  <link rel="stylesheet" href="/css/main.css">
  <!-- Componentes reutilizables -->
  <link rel="stylesheet" href="/css/components/forms.css">
  <link rel="stylesheet" href="/css/components/tables.css">
  <link rel="stylesheet" href="/css/components/badges.css">
  <link rel="stylesheet" href="/css/components/cards.css">
  <link rel="stylesheet" href="/css/components/modals.css">
  <!-- Estilos de Admin -->
  <link rel="stylesheet" href="/css/admin.css">
  <!-- CSS específicos de página (si aplica) -->
  <% if (typeof pageStylesheet !== 'undefined' && pageStylesheet) { %>
    <link rel="stylesheet" href="/css/pages/<%= pageStylesheet %>">
  <% } %>
</head>
<body class="admin-shell">
  <%- include('./adminSidebar') %>
  <main class="admin-main">
    <%- include('./alertas') %>
