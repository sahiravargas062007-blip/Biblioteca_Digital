<% const modoCatalogo=typeof catalogMode !=='undefined' ? catalogMode : 'user' ; const
  esAdminCatalogo=modoCatalogo==='admin' ; const apiCatalogo=typeof catalogApiUrl !=='undefined' ? catalogApiUrl
  : '/catalogo/api' ; const detalleBase=typeof catalogDetailBaseUrl !=='undefined' ? catalogDetailBaseUrl : '/catalogo'
  ; const tituloCatalogo=typeof catalogTitle !=='undefined' ? catalogTitle : 'Explora nuestra coleccion' ; const
  subtituloCatalogo=typeof catalogSubtitle !=='undefined' ? catalogSubtitle
  : 'Descubre recursos academicos, literarios y mas' ; const textoConteo=typeof catalogCountText !=='undefined' ?
  catalogCountText : 'recursos disponibles' ; const filtrosCatalogo=typeof filtros !=='undefined' ? filtros : {}; const
  estadosCatalogo=['Activo', 'Inactivo' , 'Pendiente de configuracion' , 'Bloqueado' ]; function iconoContenido(tipo) {
  if (tipo==='Audio' ) {
  return '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3v5zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3v5z"/></svg>'
  ; } if (tipo==='Video' ) {
  return '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>'
  ; }
  return '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>'
  ; } function iconoTipoMaterial(tipo) { const iconos={ 'Libro'
  : '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>'
  , 'Artículo'
  : '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>'
  , 'Tesis'
  : '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>'
  , 'Revista'
  : '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2z"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>'
  , 'Audiolibro'
  : '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3v5zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3v5z"/></svg>'
  , 'Video'
  : '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>'
  }; return iconos[tipo] || iconos['Libro']; } %>

  <div class="cat-main <%= esAdminCatalogo ? 'cat-main--admin' : '' %>" data-catalog-mode="<%= modoCatalogo %>"
    data-api-url="<%= apiCatalogo %>" data-detail-base-url="<%= detalleBase %>" data-count-text="<%= textoConteo %>"
    data-initial-recursos="<%= JSON.stringify(recursos) %>">
    <aside class="cat-filters">
      <div class="cat-filters__header">
        <h2>Filtros</h2>
        <button class="cat-filters__clear" id="cat-clear">Limpiar</button>
      </div>

      <div class="cat-filters__search">
        <input type="search" id="cat-search" value="<%= filtrosCatalogo.q || '' %>"
          placeholder="Buscar por titulo, autor, palabra clave...">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8" />
          <line x1="21" y1="21" x2="16.65" y2="16.65" />
        </svg>
      </div>

      <div class="cat-filters__section">
        <p class="cat-filters__section-title">Categorias</p>
        <div class="cat-tree">
          <% categorias.forEach(function(cat) { %>
            <div class="cat-tree__item">
              <div class="cat-tree__header">
                <% if (cat.subcategorias && cat.subcategorias.length) { %>
                  <span class="cat-tree__toggle">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <polyline points="9 18 15 12 9 6" />
                    </svg>
                  </span>
                  <% } else { %>
                    <span class="cat-tree__toggle" style="visibility:hidden">
                      <svg viewBox="0 0 24 24">
                        <polyline points="9 18 15 12 9 6" />
                      </svg>
                    </span>
                    <% } %>
                      <input type="checkbox" class="cat-tree__checkbox" data-cat-parent="<%= cat._id %>">
                      <span class="cat-tree__label">
                        <%= cat.nombre %>
                      </span>
              </div>
              <% if (cat.subcategorias && cat.subcategorias.length) { %>
                <div class="cat-tree__children">
                  <% cat.subcategorias.forEach(function(sub) { %>
                    <div class="cat-tree__sub">
                      <input type="checkbox" class="cat-tree__checkbox" data-cat-child="<%= cat._id %>"
                        value="<%= sub._id %>">
                      <label>
                        <%= sub.nombre %>
                      </label>
                    </div>
                    <% }) %>
                </div>
                <% } %>
            </div>
            <% }) %>
        </div>
      </div>

      <div class="cat-filters__section">
        <p class="cat-filters__section-title">Tipo de recurso</p>
        <div class="cat-filters__chips">
          <button class="cat-chip is-active" data-type-all>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="7" height="7" />
              <rect x="14" y="3" width="7" height="7" />
              <rect x="3" y="14" width="7" height="7" />
              <rect x="14" y="14" width="7" height="7" />
            </svg>
            Todos
          </button>
          <% [ { label: 'Libro' , value: 'Libro' , icon: iconoTipoMaterial('Libro') }, { label: 'Artículo' ,
            value: 'Artículo' , icon: iconoTipoMaterial('Artículo') }, { label: 'Tesis' , value: 'Tesis' , icon:
            iconoTipoMaterial('Tesis') }, { label: 'Revista' , value: 'Revista' , icon: iconoTipoMaterial('Revista') },
            { label: 'Audiolibro' , value: 'Audiolibro' , icon: iconoTipoMaterial('Audiolibro') }, { label: 'Video' ,
            value: 'Video' , icon: iconoTipoMaterial('Video') } ].forEach(function(t) { %>
            <button class="cat-chip" data-type-chip="<%= t.value %>"><%- t.icon %>
                <%= t.label %></button>
            <% }) %>
        </div>
      </div>

      <% if (esAdminCatalogo) { %>
        <div class="cat-filters__section">
          <p class="cat-filters__section-title">Estado</p>
          <div class="cat-filters__chips">
            <button class="cat-chip is-active" data-status-all>Todos</button>
            <% estadosCatalogo.forEach(function(estado) { %>
              <button class="cat-chip"
                data-status-chip="<%= estado === 'Pendiente de configuracion' ? 'Pendiente de configuración' : estado %>">
                <%= estado %>
              </button>
              <% }) %>
          </div>
        </div>
        <% } %>

          <button class="cat-filters__apply" onclick="window.catalogFetchFiltered && window.catalogFetchFiltered()">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
              <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3" />
            </svg>
            Filtrar resultados
          </button>
    </aside>

    <section class="cat-results">
      <div class="cat-results__header">
        <div>
          <h2 class="cat-results__title">
            <%= tituloCatalogo %>
          </h2>
          <p class="cat-results__subtitle">
            <%= subtituloCatalogo %>
          </p>
        </div>
        <div class="cat-results__tools">
          <span class="cat-results__count" id="cat-count">
            <%= recursos.length %>
              <%= textoConteo %>
          </span>
          <% if (esAdminCatalogo) { %>
            <a class="secondary-link" href="/admin/recursos/masivo">Carga masiva</a>
            <a class="secondary-link" href="/admin/recursos/excel-metadatos">Importar Excel</a>
            <a class="button-link" href="/admin/recursos/nuevo">Nuevo recurso</a>
            <% } %>
        </div>
      </div>

      <div class="cat-grid" id="cat-grid">
        <% if (!recursos.length) { %>
          <div class="cat-empty">
            <h2>No hay recursos para mostrar</h2>
            <p>Ajusta los filtros o la busqueda para encontrar resultados.</p>
          </div>
          <% } %>

            <% recursos.slice(0, 15).forEach(function(recurso) { %>
              <article class="cat-card <%= esAdminCatalogo ? 'cat-card--admin' : '' %>">
                <a class="cat-card__cover" href="<%= detalleBase %>/<%= recurso._id %>">
                  <img src="<%= recurso.imagen?.url || '/img/placeholder.png' %>" alt="" loading="lazy">
                  <span class="cat-card__cover-badge">
                    <%= recurso.tipo_material.toUpperCase() %>
                  </span>
                  <span class="cat-card__cover-bookmark">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z" />
                    </svg>
                  </span>
                </a>
                <div class="cat-card__body">
                  <% if (esAdminCatalogo) { %>
                    <div class="cat-card__badges">
                      <span class="cat-card__badge cat-card__badge--content"><%- iconoContenido(recurso.tipo_contenido)
                          %>
                          <%= recurso.tipo_contenido %></span>
                      <span
                        class="cat-card__badge <%= recurso.estado === 'Activo' ? 'cat-card__badge--ok' : 'cat-card__badge--muted' %>">
                        <%= recurso.estado %>
                      </span>
                    </div>
                    <% } %>
                      <h3 class="cat-card__title"><a href="<%= detalleBase %>/<%= recurso._id %>">
                          <%= recurso.titulo %>
                        </a></h3>
                      <p class="cat-card__author">
                        <%= recurso.autor %>
                      </p>
                      <div class="cat-card__tags">
                        <% if (esAdminCatalogo) { %>
                          <span class="cat-card__tag cat-card__tag--strong">
                            <%= recurso.tipo_naturaleza %>-<%= recurso.tipo_material %>
                          </span>
                          <% } %>
                            <% (recurso.categorias || []).slice(0, esAdminCatalogo ? 4 : 2).forEach(function(c) { %>
                              <span class="cat-card__tag">
                                <%= c.subcategoria_nombre || c.categoria_nombre %>
                              </span>
                              <% }) %>
                      </div>
                      <div class="cat-card__footer">
                        <span class="cat-card__type">
                          <%- iconoContenido(recurso.tipo_contenido) %>
                            <%= esAdminCatalogo ? recurso.tipo_material : recurso.tipo_material %>
                        </span>
                      </div>
                </div>
              </article>
              <% }) %>
      </div>
      <div class="cat-pagination" id="cat-pagination"></div>
    </section>
  </div>

  <script src="/js/user/catalogo.js"></script>