

<section class="panel page-title-panel">
  <a class="back-link" href="<%= backUrl %>">← Volver al recurso</a>
  <h1><%= recurso.titulo %></h1>
  <p class="author"><%= recurso.autor %></p>
</section>

<section class="panel visor-panel">

  <% if (recurso.tipo_contenido === 'Lectura') { %>

    <% if (archivo.tipo === 'epub') { %>
      <!-- ePub: visor epub.js -->
      <p class="acceso-label">📖 LEYENDO EN LA PLATAFORMA</p>
      <div id="epub-visor" style="width:100%;height:650px;border:1px solid #ddd;border-radius:8px;overflow:hidden;background:#fff;">
        <p style="padding:2rem;text-align:center;color:#888;">Cargando libro...</p>
      </div>
      <div style="display:flex;gap:1rem;margin-top:1rem;">
        <button id="prev-btn" class="btn btn-secondary">← Anterior</button>
        <button id="next-btn" class="btn btn-primary">Siguiente →</button>
      </div>
      <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
      <script src="https://cdn.jsdelivr.net/npm/epubjs/dist/epub.min.js"></script>
      <script>
        var book = ePub("<%= archivo.url %>");
        var rendition = book.renderTo("epub-visor", { width: "100%", height: 650, spread: "none" });
        rendition.display();
        document.getElementById("prev-btn").addEventListener("click", function() { rendition.prev(); });
        document.getElementById("next-btn").addEventListener("click", function() { rendition.next(); });
        document.addEventListener("keyup", function(e) {
          if (e.key === "ArrowRight") rendition.next();
          if (e.key === "ArrowLeft")  rendition.prev();
        });
      </script>

    <% } else { %>
      <!-- PDF: Google Docs Viewer como proxy de visualización -->
      <!-- Esto resuelve el problema de que Cloudinary raw no acepta transformaciones -->
      <!-- El PDF se visualiza directamente sin descargarse -->
      <p class="acceso-label">👁 VISUALIZANDO EN LA PLATAFORMA</p>
      <iframe
        src="https://docs.google.com/viewer?url=<%= encodeURIComponent(archivo.url) %>&embedded=true"
        width="100%"
        height="820"
        style="border:none;border-radius:8px;display:block;"
        title="<%= recurso.titulo %>">
      </iframe>
      <p style="font-size:0.82rem;color:#888;margin-top:0.5rem;">
        Si el visor no carga, espera unos segundos y recarga la página.
      </p>

      <!-- Botón descarga: va al servidor que hace el proxy correcto -->
      <% if (puedeDescargar && urlDescarga) { %>
        <div style="margin-top:1.25rem;">
          <a href="<%= urlDescarga %>" class="btn btn-secondary">
            ⬇ Descargar <%= archivo.tipo ? archivo.tipo.toUpperCase() : 'archivo' %>
          </a>
        </div>
      <% } %>
    <% } %>

  <% } else if (recurso.tipo_contenido === 'Audio') { %>
    <!-- Audiolibro: reproductor HTML5 nativo — funciona directo con URL de Cloudinary -->
    <p class="acceso-label">🎧 REPRODUCIENDO EN LA PLATAFORMA</p>
    <audio
      controls
      src="<%= archivo.url %>"
      style="width:100%;margin-top:1rem;border-radius:8px;">
      Tu navegador no soporta el reproductor de audio.
    </audio>

  <% } else if (recurso.tipo_contenido === 'Video') { %>
    <% if (archivo.tipo === 'url') { %>
      <p class="acceso-label">▶ RECURSO DE VIDEO</p>
      <p style="margin-bottom:1rem;">Haz clic para ver el video en la plataforma externa.</p>
      <a href="<%= archivo.url %>" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
        🔗 Ver video externo
      </a>
    <% } else { %>
      <!-- Video MP4: reproductor HTML5 nativo -->
      <p class="acceso-label">▶ REPRODUCIENDO EN LA PLATAFORMA</p>
      <video
        controls
        src="<%= archivo.url %>"
        style="width:100%;max-height:650px;border-radius:8px;background:#000;display:block;"
        title="<%= recurso.titulo %>">
        Tu navegador no soporta el reproductor de video.
      </video>
    <% } %>

  <% } else { %>
    <p>No se puede mostrar este archivo en el visor.</p>
    <a href="<%= archivo.url %>" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
      🔗 Abrir archivo
    </a>
  <% } %>

</section>
