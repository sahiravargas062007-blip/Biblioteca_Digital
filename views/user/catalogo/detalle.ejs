<%- include('../../partials/userPageStart') %>

<%
  const archivoPrincipal = recurso.digital?.archivos?.find(a => a.es_principal) || null;
  const tipoArchivo = archivoPrincipal ? archivoPrincipal.tipo : null;
  const urlArchivo  = archivoPrincipal ? archivoPrincipal.url  : null;
  const tieneAcceso = urlArchivo && recurso.disponibilidad !== 'No disponible';
%>

<section class="resource-detail-user">
  <img class="detail-cover-user"
       src="<%= recurso.imagen && recurso.imagen.url ? recurso.imagen.url : '/img/placeholder.png' %>"
       alt="Portada de <%= recurso.titulo %>">

  <div class="panel detail-panel">
    <a class="back-link" href="/catalogo">← Volver al catálogo</a>

    <div class="resource-card-meta">
      <span class="badge badge-no-disponible"><%= recurso.tipo_contenido %></span>
      <span class="badge <%= recurso.disponibilidad === 'No disponible' ? 'badge-no-disponible' : 'badge-disponible' %>">
        <%= recurso.disponibilidad %>
      </span>
    </div>

    <h1><%= recurso.titulo %></h1>
    <p class="author"><%= recurso.autor %></p>
    <p><%= recurso.descripcion %></p>

    <dl class="detail-list">
      <div><dt>Material</dt><dd><%= recurso.tipo_material %></dd></div>
      <div><dt>Naturaleza</dt><dd><%= recurso.tipo_naturaleza %></dd></div>
      <% if (recurso.editorial) { %>
        <div><dt>Editorial</dt><dd><%= recurso.editorial %></dd></div>
      <% } %>
      <% if (recurso.isbn) { %>
        <div><dt>ISBN</dt><dd><%= recurso.isbn %></dd></div>
      <% } %>
      <% if (recurso.idioma) { %>
        <div><dt>Idioma</dt><dd><%= recurso.idioma %></dd></div>
      <% } %>
    </dl>

    <div class="tag-list">
      <% (recurso.categorias || []).forEach(function(cat) { %>
        <span class="tag"><%= cat.subcategoria_nombre || cat.categoria_nombre %></span>
      <% }); %>
    </div>

    <% if (tieneAcceso) { %>
      <div class="recurso-acceso">

        <% if (tipoArchivo === 'epub') { %>
          <!-- ePub: visor integrado con epub.js -->
          <p class="acceso-label">Lectura en línea</p>
          <div id="epub-visor" style="width:100%;height:600px;border:1px solid #ddd;border-radius:8px;overflow:hidden;">
            <p style="padding:2rem;text-align:center;">Cargando libro...</p>
          </div>
          <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
          <script src="https://cdn.jsdelivr.net/npm/epubjs/dist/epub.min.js"></script>
          <script>
            var book = ePub("<%= urlArchivo %>");
            var rendition = book.renderTo("epub-visor", {
              width: "100%",
              height: 600,
              spread: "none"
            });
            rendition.display();
            document.addEventListener("keyup", function(e) {
              if (e.key === "ArrowRight") rendition.next();
              if (e.key === "ArrowLeft")  rendition.prev();
            });
          </script>
          <div class="epub-nav">
            <button onclick="rendition.prev()" class="btn btn-secondary">← Anterior</button>
            <button onclick="rendition.next()" class="btn btn-primary">Siguiente →</button>
          </div>

        <% } else if (tipoArchivo === 'pdf') { %>
          <!-- PDF: descarga directa -->
          <a href="<%= urlArchivo %>" download class="btn btn-primary btn-acceso">
            ⬇ Descargar PDF
          </a>

        <% } else if (tipoArchivo === 'mp3') { %>
          <!-- MP3: descarga directa -->
          <a href="<%= urlArchivo %>" download class="btn btn-primary btn-acceso">
            ⬇ Descargar Audiolibro (MP3)
          </a>

        <% } else if (tipoArchivo === 'mp4') { %>
          <!-- MP4: descarga directa -->
          <a href="<%= urlArchivo %>" download class="btn btn-primary btn-acceso">
            ⬇ Descargar Video (MP4)
          </a>

        <% } else if (tipoArchivo === 'url') { %>
          <!-- URL externa -->
          <a href="<%= urlArchivo %>" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-acceso">
            🔗 Acceder al recurso
          </a>
        <% } %>

      </div>
    <% } else if (urlArchivo && recurso.disponibilidad === 'No disponible') { %>
      <p class="acceso-no-disponible">
        Este recurso no está disponible actualmente. Puedes reservarlo para cuando quede libre.
      </p>
    <% } %>

  </div>
</section>

<%- include('../../partials/userPageEnd') %>
