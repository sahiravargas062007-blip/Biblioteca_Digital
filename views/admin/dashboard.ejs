<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %> | Biblioteca Digital</title>
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-shell">
  <%- include('../partials/adminSidebar') %>

  <main class="admin-main">
    <%- include('../partials/alertas') %>

    <section class="panel page-header">
      <div>
        <p class="eyebrow">Administración</p>
        <h1>Panel administrador</h1>
      </div>
      <form method="post" action="/admin/logout">
        <button class="danger-button" type="submit">Cerrar sesión</button>
      </form>
    </section>

    <section class="summary-grid">
      <article class="summary-card">
        <span>Usuarios pendientes</span>
        <strong><%= resumen.usuariosPendientes %></strong>
      </article>
      <article class="summary-card">
        <span>Préstamos activos</span>
        <strong><%= resumen.prestamosActivos %></strong>
      </article>
      <article class="summary-card">
        <span>Sanciones activas</span>
        <strong><%= resumen.sancionesActivas %></strong>
      </article>
    </section>
  </main>
</body>
</html>
