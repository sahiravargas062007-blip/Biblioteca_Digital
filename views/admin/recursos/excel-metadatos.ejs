<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %> | Biblioteca Digital</title>
  <!-- CSS Base -->
  <link rel="stylesheet" href="/css/main.css">
  <!-- Componentes -->
  <link rel="stylesheet" href="/css/components/forms.css">
  <link rel="stylesheet" href="/css/components/tables.css">
  <!-- Estilos de Admin -->
  <link rel="stylesheet" href="/css/admin.css">
  <!-- Página específica -->
  <link rel="stylesheet" href="/css/pages/admin-recursos.css">
</head>
<body class="admin-shell">
  <%- include('../../partials/adminSidebar') %>

  <main class="admin-main">
    <%- include('../../partials/alertas') %>

    <section class="panel page-header">
      <div>
        <p class="eyebrow">Actualización por lotes</p>
        <h1>Importar metadatos desde Excel</h1>
      </div>
      <a class="secondary-link" href="/admin/recursos">Volver</a>
    </section>

    <% if (typeof resultados === 'undefined' || !resultados) { %>
    <section class="panel">
      <h2>Subir archivo Excel</h2>
      <p class="form-hint" style="margin-bottom:1rem">
        Cargue un archivo <code>.xlsx</code> o <code>.csv</code> con los metadatos de sus recursos.<br>
        <strong>Columna clave:</strong> "Nombre del Archivo" (sin extensión, ej: libro1, video1).<br>
        <strong>Campos actualizables:</strong> Título, Autor, Descripción, ISBN, Clasificación, Editorial, Fecha Publicación, Duración, Idioma, Páginas, Narrador (para audio), Director (para video), Productora (para video), URL de imagen.<br>
        <strong>Tipos de contenido:</strong> El sistema detecta automáticamente si es Lectura, Audio o Video basado en los campos presentes (Narrador = Audio, Director = Video).
      </p>

      <form
        class="form-stack"
        method="post"
        action="/admin/recursos/excel-metadatos/procesar"
        enctype="multipart/form-data"
        onsubmit="this.classList.add('submitting')"
      >
        <label>
          Archivo Excel <small>(máx. 10 MB)</small>
          <input type="file" name="excel" accept=".xlsx,.csv,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,text/csv" required>
        </label>

        <label>
          <input type="checkbox" name="auto_publicar" value="true">
          Publicar automáticamente recursos completados (cuando tengan título y clasificación)
        </label>

        <div class="panel-note">
          <strong>Formato del Excel:</strong><br>
          - Primera fila: encabezados (ej: "Nombre del Archivo", "Título", "Autor", etc.)<br>
          - Columnas opcionales: use los nombres exactos o similares para que el sistema los reconozca.<br>
          - Para audio: incluya "Narrador", "Duración" (HH:MM:SS)<br>
          - Para video: incluya "Director", "Productora", "Duración"<br>
          - Imagen: use "URL de imagen" o "Imagen URL"<br>
          El sistema buscará cada "Nombre del Archivo" en la base de datos y actualizará solo los campos presentes en el Excel. 
          Si un recurso no existe, se reportará como error pero no se creará uno nuevo.
        </div>

        <div class="form-actions">
          <button type="submit">
            <span class="btn-label">Procesar Excel →</span>
            <span class="btn-spinner"><span class="spinner-icon"></span> Procesando…</span>
          </button>
          <a class="secondary-link" href="/admin/recursos">Cancelar</a>
        </div>
      </form>
    </section>

    <% } else { %>
    <section class="panel">
      <h2>Resultados de la importación</h2>

      <!-- Resumen -->
      <div class="summary-bar">
        <div class="summary-stat">
          <strong><%= resultados.procesados %></strong>
          Procesados
        </div>
        <div class="summary-stat">
          <strong style="color:#065f46"><%= resultados.exitosos %></strong>
          Actualizados
        </div>
        <div class="summary-stat">
          <strong style="color:#991b1b"><%= resultados.errores.length %></strong>
          Con errores
        </div>
        <% if (resultados.publicados) { %>
        <div class="summary-stat">
          <strong style="color:#0369a1"><%= resultados.publicados %></strong>
          Publicados
        </div>
        <% } %>
      </div>

      <!-- Errores detallados -->
      <% if (resultados.errores.length > 0) { %>
      <div class="errores-lista">
        <strong style="font-size:.9rem">Problemas detectados:</strong>
        <ul style="margin:.5rem 0 0; padding-left:1.2rem">
          <% resultados.errores.forEach(e => { %>
          <li><%= e %></li>
          <% }) %>
        </ul>
      </div>
      <% } %>

      <!-- Detalles actualizados -->
      <% if (resultados.detalles && resultados.detalles.length > 0) { %>
      <div style="margin-top:1.5rem; overflow-x:auto">
        <h3 style="font-size:1rem; margin-bottom:.75rem">Recursos actualizados</h3>
        <table class="resultado-tabla">
          <thead>
            <tr>
              <th>Archivo</th>
              <th>Título</th>
              <th>Estado</th>
            </tr>
          </thead>
          <tbody>
            <% resultados.detalles.forEach(d => { %>
            <tr>
              <td><small style="color:var(--text-muted,#6b7280)"><%= d.nombreArchivo %></small></td>
              <td><strong><%= d.titulo %></strong></td>
              <td>
                <span class="badge-ok">Actualizado</span>
                <% if (d.publicado) { %>
                  <span class="badge-ok" style="margin-left:.25rem">Publicado</span>
                <% } %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>

      <div class="form-actions" style="margin-top:1.5rem">
        <a class="secondary-link" href="/admin/recursos/excel-metadatos">Cargar otro Excel</a>
        <a class="secondary-link" href="/admin/recursos">Ver recursos</a>
      </div>
    </section>
    <% } %>

  </main>
</body>
</html>
