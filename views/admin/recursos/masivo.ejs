<link rel="stylesheet" href="/css/components/forms.css">
<link rel="stylesheet" href="/css/components/tables.css">
<link rel="stylesheet" href="/css/pages/admin-recursos.css">

<section class="panel page-header">
      <div>
        <p class="eyebrow">Registro por lotes</p>
        <h1>Carga masiva ZIP</h1>
      </div>
      <a class="secondary-link" href="/admin/recursos">Volver</a>
    </section>

    <% if (typeof previsualizar === 'undefined' || !previsualizar) { %>
    <%
      /*
       * ─────────────────────────────────────────────────────────────────────
       * PASO 1 — Formulario inicial: el admin selecciona el ZIP
       * ─────────────────────────────────────────────────────────────────────
       */
    %>
    <section class="panel">
      <h2>Subir archivo ZIP</h2>
      <p class="form-hint" style="margin-bottom:1rem">
        El sistema aceptará las siguientes estructuras internas:<br>
        <strong>Estructura plana</strong> — archivos sueltos asociados por nombre (ej: <code>libro1.pdf</code> y <code>libro1.jpg</code>).<br>
        <strong>Estructura por carpetas</strong> — cada subcarpeta = 1 recurso; el nombre de la carpeta se usa como título provisional.
      </p>

      <form
        class="form-stack"
        method="post"
        action="/admin/recursos/masivo/previsualizar"
        enctype="multipart/form-data"
        onsubmit="this.classList.add('submitting')"
      >
        <label>
          Tipo de contenido del ZIP
          <select name="tipo_contenido" required>
            <option value="Lectura">Lectura — Principal: PDF / ePub, Portada: imagen, Complemento: MP3</option>
            <option value="Audio">Audio — Principal: MP3, Portada: imagen</option>
            <option value="Video">Video — Principal: MP4, Portada: imagen</option>
          </select>
        </label>

        <label>
          Archivo ZIP <small>(máx. 500 MB)</small>
          <input type="file" name="zip" accept=".zip,application/zip,application/x-zip-compressed" required>
        </label>

        <div class="panel-note">
          Los recursos se crearán con estado <strong>Pendiente de configuración</strong> y no serán visibles al público hasta que complete sus metadatos individualmente.
        </div>

        <div class="form-actions">
          <button type="submit">
            <span class="btn-label">Analizar ZIP →</span>
            <span class="btn-spinner"><span class="spinner-icon"></span> Analizando…</span>
          </button>
          <a class="secondary-link" href="/admin/recursos">Cancelar</a>
        </div>
      </form>
    </section>

    <% } else { %>
    <%
      /*
       * ─────────────────────────────────────────────────────────────────────
       * PASO 2 — Vista previa: el admin revisa y confirma o cancela (CA4)
       * ─────────────────────────────────────────────────────────────────────
       */
        const nuevos = recursos.filter(r => r.estadoDeteccion === 'Nuevo');
        const pendientes = recursos.filter(r => r.estadoDeteccion === 'Archivo pendiente encontrado');
        const ignorados = recursos.filter(r => r.estadoDeteccion === 'Ya existente con archivo');
        const erroresDet = recursos.filter(r => r.estadoDeteccion === 'Error');
        const validos = [...nuevos, ...pendientes];
      %>
      <section class="panel">
        <h2>Vista previa de la carga</h2>
        <p class="form-hint">
          Revise los recursos detectados antes de confirmar. <strong>Nuevos</strong> se crearán. <strong>Pendientes</strong> recibirán el archivo. <strong>Ya existentes</strong> se ignorarán.
        </p>

        <!-- Resumen estadístico -->
        <div class="summary-bar">
          <div class="summary-stat">
            <strong><%= recursos.length %></strong>
            Total detectados
          </div>
          <div class="summary-stat">
            <strong style="color:#065f46"><%= nuevos.length %></strong>
            Nuevos a crear
          </div>
          <div class="summary-stat">
            <strong style="color:#0369a1"><%= pendientes.length %></strong>
            Archivos a adjuntar
          </div>
          <div class="summary-stat">
            <strong style="color:#9ca3af"><%= ignorados.length %></strong>
            Ya existentes (ignorados)
          </div>
          <div class="summary-stat">
            <strong style="color:#991b1b"><%= erroresDet.length %></strong>
            Con errores
          </div>
        </div>

        <!-- Tabla de recursos detectados -->
        <% if (recursos.length > 0) { %>
        <div style="overflow-x:auto">
          <table class="preview-table">
            <thead>
              <tr>
                <th>#</th>
                <th>Título provisional</th>
                <th>Estado</th>
                <th>Clasificación</th>
                <th>Portada</th>
              </tr>
            </thead>
            <tbody>
              <% recursos.forEach((r, i) => { %>
              <tr>
                <td style="color:var(--text-muted,#6b7280);font-size:.8rem"><%= i + 1 %></td>
                <td><strong><%= r.titulo %></strong></td>
                <td>
                  <% if (r.tieneMain) { %>
                    <span class="badge-ok">Listo</span>
                  <% } else { %>
                    <span class="badge-error">Sin archivo principal</span>
                  <% } %>
                </td>
                <td>
                  <% if (r.estadoDeteccion === 'Nuevo') { %>
                    <span class="badge-ok" style="background:#dcfce7;color:#166534">Nuevo</span>
                  <% } else if (r.estadoDeteccion === 'Archivo pendiente encontrado') { %>
                    <span class="badge-warn" style="background:#dbeafe;color:#1e40af">Pendiente encontrado</span>
                  <% } else if (r.estadoDeteccion === 'Ya existente con archivo') { %>
                    <span style="background:#f3f4f6;color:#374151;padding:2px 6px;border-radius:4px;font-size:0.75rem">Ya existente</span>
                  <% } else { %>
                    <span class="badge-error">Error</span>
                  <% } %>
                </td>
                <td>
                  <% if (r.tienePortada) { %>
                    <span class="badge-ok">Incluida</span>
                  <% } else { %>
                    <span class="badge-warn">Placeholder</span>
                  <% } %>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>

      <!-- Errores de detección (CA4) -->
      <% if (errores && errores.length > 0) { %>
      <div class="errores-lista">
        <strong style="font-size:.9rem">Problemas detectados:</strong>
        <ul style="margin:.5rem 0 0; padding-left:1.2rem">
          <% errores.forEach(e => { %>
          <li><%= e %></li>
          <% }) %>
        </ul>
      </div>
      <% } %>

      <!-- Formulario de confirmación / cancelación (CA5 y CA6) -->
      <form
        class="form-stack"
        method="post"
        action="/admin/recursos/masivo/confirmar"
        style="margin-top:1.5rem"
        onsubmit="if(this.accion && this.accion.value!=='cancelar') this.classList.add('submitting')"
      >
        <!-- El ZIP temporal se identifica por nombre de archivo para no reenviar el contenido completo -->
        <input type="hidden" name="tipo_contenido" value="<%= tipoContenido %>">
        <input type="hidden" name="zip_temp_name" value="<%= zipTempName %>">

        <% if (validos.length > 0) { %>
        <div class="panel-note">
          Se procesarán <strong><%= validos.length %> recurso(s)</strong> (Nuevos + Pendientes).
          Este proceso puede tardar varios minutos dependiendo del tamaño de los archivos.
        </div>
        <% } else { %>
        <div class="panel-note">
          No hay recursos válidos para procesar (todos son errores o ya existen).
        </div>
        <% } %>

        <div class="form-actions">
          <button type="submit" name="accion" value="confirmar" <%= validos.length === 0 ? 'disabled' : '' %>>
            <span class="btn-label">Confirmar y procesar (<%= validos.length %>)</span>
            <span class="btn-spinner"><span class="spinner-icon"></span> Procesando…</span>
          </button>
          <!-- CA6: cancelar limpia sin guardar nada -->
          <button
            type="submit"
            name="accion"
            value="cancelar"
            class="secondary-link"
            style="background:none;border:none;cursor:pointer;padding:0"
          >Cancelar y descartar</button>
        </div>
      </form>
    </section>
    <% } %>
