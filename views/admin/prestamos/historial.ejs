<link rel="stylesheet" href="/css/components/tables.css">
<link rel="stylesheet" href="/css/components/badges.css">

<section class="panel page-header">
      <div>
        <p class="eyebrow">Consulta histórica</p>
        <h1>Historial de préstamos</h1>
      </div>
      <a class="secondary-link" href="/admin/prestamos">Volver</a>
    </section>
    <section class="panel">
      <form class="toolbar" method="get" action="/admin/prestamos/historial">
        <label>Buscar <input type="search" name="q" value="<%= q %>"></label>
        <button>Filtrar</button>
      </form>
      <div class="table-wrap">
        <table class="table">
          <thead><tr><th>Usuario</th><th>Tipo</th><th>Ítems</th><th>Estado</th><th>Fecha</th></tr></thead>
          <tbody>
            <% prestamos.forEach((prestamo) => { %>
              <tr>
                <td><%= prestamo.usuario_nombre %><small><%= prestamo.usuario_documento %></small></td>
                <td><%= prestamo.tipo %></td>
                <td><%= prestamo.items.length %></td>
                <td><%= prestamo.estado %></td>
                <td><%= new Date(prestamo.creado_en).toLocaleDateString('es-CO') %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>
