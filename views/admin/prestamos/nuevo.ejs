<link rel="stylesheet" href="/css/components/tables.css">
<link rel="stylesheet" href="/css/components/forms.css">
<link rel="stylesheet" href="/css/components/badges.css">

<section class="panel page-header">
      <div>
        <p class="eyebrow">Registro manual</p>
        <h1>Nuevo préstamo físico</h1>
      </div>
      <a class="secondary-link" href="/admin/prestamos">Volver</a>
    </section>

    <section class="panel">
      <form method="post" action="/admin/prestamos" class="form-stack">
        <label>
          Usuario activo
          <select name="usuario_id" required>
            <option value="">Seleccione un usuario</option>
            <% usuarios.forEach((usuario) => { %>
              <option value="<%= usuario._id %>"><%= usuario.nombre %> · <%= usuario.documento %> · préstamos activos: <%= usuario.prestamos_activos || 0 %></option>
            <% }) %>
          </select>
        </label>

        <div>
          <h2>Ejemplares disponibles</h2>
          <div class="table-wrap">
            <table class="table">
              <thead>
                <tr>
                  <th>Seleccionar</th>
                  <th>Recurso</th>
                  <th>Código</th>
                  <th>Estado</th>
                </tr>
              </thead>
              <tbody>
                <% if (!ejemplares.length) { %>
                  <tr><td colspan="4">No hay ejemplares disponibles.</td></tr>
                <% } %>
                <% ejemplares.forEach((ejemplar) => { %>
                  <tr>
                    <td><input type="checkbox" name="ejemplar_ids" value="<%= ejemplar._id %>"></td>
                    <td><%= ejemplar.recurso_titulo %></td>
                    <td><%= ejemplar.codigo_inventario %></td>
                    <td><span class="badge badge-disponible"><%= ejemplar.estado %></span></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>

        <div class="form-actions">
          <button type="submit">Registrar préstamo</button>
          <a class="secondary-link" href="/admin/prestamos">Cancelar</a>
        </div>
      </form>
    </section>
