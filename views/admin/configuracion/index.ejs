
  <section class="panel page-title-panel">
    <p class="eyebrow">Sistema</p>
    <h1>Configuración</h1>
    <p class="muted">Ajusta los parámetros de préstamos, reservas y sanciones del sistema.</p>
  </section>

  <section class="panel">
    <h2>Préstamos físicos</h2>
    <form method="post" action="/admin/configuracion?_method=PUT" class="form-stack">
      <label>
        Máximo de préstamos activos por usuario
        <input type="number" name="max_prestamos_fisicos" value="<%= config.prestamos_fisicos.max_recursos_por_usuario %>" min="1" max="20">
      </label>
      <label>
        Días de préstamo (defecto)
        <input type="number" name="dias_prestamo" value="<%= config.prestamos_fisicos.dias_prestamo_defecto %>" min="1" max="60">
      </label>
      <label>
        Días de renovación
        <input type="number" name="dias_renovacion" value="<%= config.prestamos_fisicos.dias_renovacion %>" min="1" max="30">
      </label>
      <label>
        Máximo de renovaciones por préstamo
        <input type="number" name="max_renovaciones" value="<%= config.prestamos_fisicos.max_renovaciones %>" min="0" max="5">
      </label>
      <label>
        Días de tolerancia para vencimiento
        <input type="number" name="dias_tolerancia" value="<%= config.prestamos_fisicos.dias_tolerancia %>" min="0" max="10">
      </label>

      <hr>

      <h2>Préstamos digitales</h2>
      <label>
        Máximo de préstamos digitales por usuario
        <input type="number" name="max_prestamos_digitales" value="<%= config.prestamos_digitales.max_prestamos_por_usuario %>" min="1" max="50">
      </label>
      <label>
        Duración defecto (días)
        <input type="number" name="duracion_digital" value="<%= config.prestamos_digitales.duracion_defecto_dias %>" min="1" max="60">
      </label>
      <label>
        Renovaciones permitidas
        <input type="number" name="renovaciones_digitales" value="<%= config.prestamos_digitales.renovaciones_permitidas %>" min="0" max="5">
      </label>

      <hr>

      <h2>Reservas</h2>
      <label>
        Máximo de reservas por usuario
        <input type="number" name="max_reservas" value="<%= config.reservas.max_reservas_por_usuario %>" min="1" max="10">
      </label>
      <label>
        Tiempo máximo de reclamo (horas)
        <input type="number" name="tiempo_reclamo_horas" value="<%= config.reservas.tiempo_max_reclamo_horas %>" min="1" max="72">
      </label>

      <hr>

      <h2>Sanciones disciplinarias (Matriz de reglas)</h2>
      
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem;">
        <label>
          Días máximo retraso Leve
          <input type="number" name="retraso_leve_max_dias" value="<%= config.sanciones?.retraso_leve_max_dias !== undefined ? config.sanciones.retraso_leve_max_dias : 3 %>" min="1" max="15" placeholder="Por defecto: 3">
          <small class="muted" style="font-size: 0.75rem;">(Por defecto: 1-3 días. Leve)</small>
        </label>
        <label>
          Días máximo retraso Moderada
          <input type="number" name="retraso_moderada_max_dias" value="<%= config.sanciones?.retraso_moderada_max_dias !== undefined ? config.sanciones.retraso_moderada_max_dias : 7 %>" min="1" max="30" placeholder="Por defecto: 7">
          <small class="muted" style="font-size: 0.75rem;">(Por defecto: 4-7 días. Moderada. 8+ Grave)</small>
        </label>
      </div>

      <%
      const combos = [
        { idx: 0, tipo: 'Retraso', gravedad: 'Leve' },
        { idx: 1, tipo: 'Retraso', gravedad: 'Moderada' },
        { idx: 2, tipo: 'Retraso', gravedad: 'Grave' },
        { idx: 3, tipo: 'Daño',    gravedad: 'Leve' },
        { idx: 4, tipo: 'Daño',    gravedad: 'Moderada' },
        { idx: 5, tipo: 'Daño',    gravedad: 'Grave' },
        { idx: 6, tipo: 'Pérdida', gravedad: 'Grave' }
      ];
      function findRegla(tipo, gravedad) {
        return (config.sanciones?.reglas || []).find(r => r.tipo_incidencia === tipo && r.gravedad === gravedad) || {
          tipo_incidencia: tipo,
          gravedad: gravedad,
          tipo_sancion: 'Advertencia',
          dias_suspension: 0,
          suspension_adicional: false
        };
      }
      %>

      <div class="table-wrap">
        <table class="matrix-table">
          <thead>
            <tr>
              <th>Incidencia</th>
              <th>Leve</th>
              <th>Moderada</th>
              <th>Grave</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><strong>Retraso</strong></td>
              <% [0, 1, 2].forEach(idx => {
                const item = combos[idx];
                const regla = findRegla(item.tipo, item.gravedad);
              %>
                <td>
                  <div class="matrix-cell">
                    <input type="hidden" name="reglas[<%= item.idx %>][tipo_incidencia]" value="<%= item.tipo %>">
                    <input type="hidden" name="reglas[<%= item.idx %>][gravedad]" value="<%= item.gravedad %>">
                    
                    <select name="reglas[<%= item.idx %>][tipo_sancion]" id="tipo_sancion_<%= item.idx %>">
                      <option value="Advertencia" <%= regla.tipo_sancion === 'Advertencia' ? 'selected' : '' %>>Advertencia</option>
                      <option value="Suspensión" <%= regla.tipo_sancion === 'Suspensión' ? 'selected' : '' %>>Suspensión</option>
                      <option value="Reposición" <%= regla.tipo_sancion === 'Reposición' ? 'selected' : '' %>>Reposición</option>
                    </select>

                    <div class="checkbox-container-add" id="checkbox-container-add-<%= item.idx %>" style="display: none;">
                      <label class="checkbox-inline">
                        <input type="checkbox" name="reglas[<%= item.idx %>][suspension_adicional]" id="chk-add-<%= item.idx %>" <%= regla.suspension_adicional ? 'checked' : '' %>>
                        <small>Suspensión adicional</small>
                      </label>
                    </div>

                    <div class="days-container" id="days-container-<%= item.idx %>" style="display: none;">
                      <label id="days-label-<%= item.idx %>"><small>Días:</small></label>
                      <input type="number" name="reglas[<%= item.idx %>][dias_suspension]" id="days-input-<%= item.idx %>" value="<%= regla.dias_suspension %>" min="1">
                    </div>
                  </div>
                </td>
              <% }) %>
            </tr>

            <tr>
              <td><strong>Daño</strong></td>
              <% [3, 4, 5].forEach(idx => {
                const item = combos[idx];
                const regla = findRegla(item.tipo, item.gravedad);
              %>
                <td>
                  <div class="matrix-cell">
                    <input type="hidden" name="reglas[<%= item.idx %>][tipo_incidencia]" value="<%= item.tipo %>">
                    <input type="hidden" name="reglas[<%= item.idx %>][gravedad]" value="<%= item.gravedad %>">
                    
                    <select name="reglas[<%= item.idx %>][tipo_sancion]" id="tipo_sancion_<%= item.idx %>">
                      <option value="Advertencia" <%= regla.tipo_sancion === 'Advertencia' ? 'selected' : '' %>>Advertencia</option>
                      <option value="Suspensión" <%= regla.tipo_sancion === 'Suspensión' ? 'selected' : '' %>>Suspensión</option>
                      <option value="Reposición" <%= regla.tipo_sancion === 'Reposición' ? 'selected' : '' %>>Reposición</option>
                    </select>

                    <div class="checkbox-container-add" id="checkbox-container-add-<%= item.idx %>" style="display: none;">
                      <label class="checkbox-inline">
                        <input type="checkbox" name="reglas[<%= item.idx %>][suspension_adicional]" id="chk-add-<%= item.idx %>" <%= regla.suspension_adicional ? 'checked' : '' %>>
                        <small>Suspensión adicional</small>
                      </label>
                    </div>

                    <div class="days-container" id="days-container-<%= item.idx %>" style="display: none;">
                      <label id="days-label-<%= item.idx %>"><small>Días:</small></label>
                      <input type="number" name="reglas[<%= item.idx %>][dias_suspension]" id="days-input-<%= item.idx %>" value="<%= regla.dias_suspension %>" min="1">
                    </div>
                  </div>
                </td>
              <% }) %>
            </tr>

            <tr>
              <td><strong>Pérdida</strong></td>
              <% 
                const itemPerdida = combos[6];
                const reglaPerdida = findRegla(itemPerdida.tipo, itemPerdida.gravedad);
              %>
              <td colspan="3">
                <div class="matrix-cell" style="max-width: 320px;">
                  <input type="hidden" name="reglas[<%= itemPerdida.idx %>][tipo_incidencia]" value="<%= itemPerdida.tipo %>">
                  <input type="hidden" name="reglas[<%= itemPerdida.idx %>][gravedad]" value="<%= itemPerdida.gravedad %>">
                  
                  <select name="reglas[<%= itemPerdida.idx %>][tipo_sancion]" id="tipo_sancion_<%= itemPerdida.idx %>">
                    <option value="Advertencia" <%= reglaPerdida.tipo_sancion === 'Advertencia' ? 'selected' : '' %>>Advertencia</option>
                    <option value="Suspensión" <%= reglaPerdida.tipo_sancion === 'Suspensión' ? 'selected' : '' %>>Suspensión</option>
                    <option value="Reposición" <%= reglaPerdida.tipo_sancion === 'Reposición' ? 'selected' : '' %>>Reposición</option>
                  </select>

                  <div class="checkbox-container-add" id="checkbox-container-add-<%= itemPerdida.idx %>" style="display: none;">
                    <label class="checkbox-inline">
                      <input type="checkbox" name="reglas[<%= itemPerdida.idx %>][suspension_adicional]" id="chk-add-<%= itemPerdida.idx %>" <%= reglaPerdida.suspension_adicional ? 'checked' : '' %>>
                      <small>Suspensión adicional</small>
                    </label>
                  </div>

                  <div class="days-container" id="days-container-<%= itemPerdida.idx %>" style="display: none;">
                    <label id="days-label-<%= itemPerdida.idx %>"><small>Días:</small></label>
                    <input type="number" name="reglas[<%= itemPerdida.idx %>][dias_suspension]" id="days-input-<%= itemPerdida.idx %>" value="<%= reglaPerdida.dias_suspension %>" min="1">
                  </div>
                </div>
              </td>
            </tr>
          </tbody>
        </table>
      </div>

      <style>
        .matrix-table {
          width: 100%;
          border-collapse: collapse;
          margin: 1.5rem 0;
        }
        .matrix-table th, .matrix-table td {
          padding: 0.75rem;
          border: 1px solid var(--border-color, #e2e8f0);
          text-align: left;
          vertical-align: top;
        }
        .matrix-table th {
          background-color: var(--background-secondary, #f8fafc);
          font-weight: 600;
        }
        .matrix-cell {
          display: flex;
          flex-direction: column;
          gap: 0.5rem;
        }
        .matrix-cell select, .matrix-cell input[type="number"] {
          width: 100%;
          padding: 0.35rem 0.5rem;
          border: 1px solid var(--border-color, #e2e8f0);
          border-radius: 0.25rem;
          font-size: 0.875rem;
        }
        .checkbox-inline {
          display: inline-flex;
          align-items: center;
          gap: 0.25rem;
          font-size: 0.85rem;
          cursor: pointer;
        }
        .checkbox-inline input {
          margin: 0;
          cursor: pointer;
        }
        .days-container {
          margin-top: 0.25rem;
        }
        .days-container label {
          display: block;
          margin-bottom: 0.15rem;
          font-size: 0.75rem;
          color: var(--text-muted, #718096);
        }
      </style>

      <script>
        document.addEventListener('DOMContentLoaded', function() {
          const combos = [0, 1, 2, 3, 4, 5, 6];
          
          function updateCell(idx) {
            const select = document.getElementById(`tipo_sancion_${idx}`);
            const val = select.value;
            const daysContainer = document.getElementById(`days-container-${idx}`);
            const chkContainer = document.getElementById(`checkbox-container-add-${idx}`);
            const chk = document.getElementById(`chk-add-${idx}`);
            const label = document.getElementById(`days-label-${idx}`);
            
            if (val === 'Advertencia') {
              daysContainer.style.display = 'none';
              chkContainer.style.display = 'none';
            } else if (val === 'Suspensión') {
              daysContainer.style.display = 'block';
              chkContainer.style.display = 'none';
              label.textContent = 'Días de suspensión:';
            } else if (val === 'Reposición') {
              chkContainer.style.display = 'block';
              label.textContent = 'Días adicionales:';
              if (chk.checked) {
                daysContainer.style.display = 'block';
              } else {
                daysContainer.style.display = 'none';
              }
            }
          }

          combos.forEach(idx => {
            const select = document.getElementById(`tipo_sancion_${idx}`);
            const chk = document.getElementById(`chk-add-${idx}`);
            
            if (select) {
              select.addEventListener('change', () => updateCell(idx));
            }
            if (chk) {
              chk.addEventListener('change', () => updateCell(idx));
            }
            
            // Inicializar
            updateCell(idx);
          });
        });
      </script>

      <button type="submit">Guardar configuración</button>
    </form>
  </section>

